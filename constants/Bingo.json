{
  "bingo_tips": {
    "Good Will Hunting (Community Goal)": {
      "difficulty": "Medium",
      "note": [
        "Hunt Mobs"
      ],
      "found": "Bloxigus",
      "guide": [
        "For this you'll need a Pocket Black Hole",
        "and a Hunting Axe from the Galatea Quests."
      ]
    },
    "Lord of the Flies (Community Goal)": {
      "difficulty": "Medium",
      "note": [
        "Catch pests with traps"
      ],
      "found": "Bloxigus",
      "guide": [
        "The first tier of traps costs 50 Pests",
        "from Pesthunter Philip in the Garden.",
        "You'll also need a Vacuum to collect them."
      ]
    },
    "Journey to the Center of the Earth (Community Goal)": {
      "difficulty": "Easy",
      "note": [
        "Complete Mining Commissions"
      ],
      "found": "Bloxigus",
      "guide": [
        "For this you'll want to talk to the King",
        "in the Dwarven Mines and do what he tells",
        "you to. Buy yourself better pickaxes from",
        "Bubu to help with this."
      ]
    },
    "The Lorax (Community Goal)": {
      "difficulty": "Easy",
      "note": [
        "Collect Tree Gifts"
      ],
      "found": "Bloxigus",
      "guide": [
        "For this you'll want to utilize",
        "Canopy Armor from Amaury in Galatea.",
        "You'll need to contribute at least 10%",
        "to a tree cut to get one."
      ]
    },
    "Treasure Island (Community Goal)": {
      "difficulty": "Easy",
      "note": [
        "Fish up trash in Backwater Bayou"
      ],
      "found": "Bloxigus",
      "guide": [
        "For this you'll need to apply the Junk Sinker",
        "from Junker Joel in the Backwater Bayou to",
        "your rod and fish with it."
      ]
    },
